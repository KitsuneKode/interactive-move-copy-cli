{
  "name": "@kitsunekode/file-ops-cli",
  "version": "1.0.0",
  "description": "Interactive Bun-native file move, copy, and remove CLIs with shared safety-first workflows.",
  "type": "module",
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitsuneKode/interactive-move-copy-cli.git"
  },
  "homepage": "https://github.com/KitsuneKode/interactive-move-copy-cli#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/interactive-move-copy-cli/issues"
  },
  "keywords": [
    "bun",
    "cli",
    "copy",
    "files",
    "interactive",
    "move",
    "remove",
    "terminal",
    "trash",
    "tui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist/cpi.js",
    "dist/mvi.js",
    "dist/rmi.js",
    "completions",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "mvi": "./bin/mvi",
    "cpi": "./bin/cpi",
    "rmi": "./bin/rmi"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:js:mvi": "bun build --minify --target=bun --outfile dist/mvi.js src/bin/mvi-build.ts",
    "build:js:cpi": "bun build --minify --target=bun --outfile dist/cpi.js src/bin/cpi-build.ts",
    "build:js:rmi": "bun build --minify --target=bun --outfile dist/rmi.js src/bin/rmi-build.ts",
    "build": "bun run clean && bun run build:js:mvi && bun run build:js:cpi && bun run build:js:rmi",
    "build:compile:mvi": "bun build --compile --target=bun --outfile dist/mvi src/bin/mvi-build.ts",
    "build:compile:cpi": "bun build --compile --target=bun --outfile dist/cpi src/bin/cpi-build.ts",
    "build:compile:rmi": "bun build --compile --target=bun --outfile dist/rmi src/bin/rmi-build.ts",
    "build:compile": "bun run build:compile:mvi && bun run build:compile:cpi && bun run build:compile:rmi",
    "config:init": "bun run src/scripts/config-init.ts",
    "config:edit": "bun run src/scripts/config-edit.ts",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run lint:md && bun test",
    "pkg:check": "bun run build && npm pack --dry-run --ignore-scripts",
    "link:global": "bun run config:init && bun run build && bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun unlink && bun run link:global",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check && bun run build",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "prepare": "[ -f .git/config ] && [ -w .git/config ] && husky || echo 'Skipping husky install (no writable .git config)'",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.worktrees\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#.worktrees\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "@biomejs/biome": "^2.4.6",
    "markdownlint-cli2": "^0.21.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
